{
  "name": "@jfalava/hyperscaler-services",
  "version": "0.4.1-20260723",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vp lint && vp build",
    "cf-typegen": "wrangler types",
    "check": "vp lint --type-check --fix",
    "deploy": "vp check && vp build && wrangler deploy",
    "dev": "wrangler types && vp dev --port 3000",
    "format": "vp fmt",
    "lint": "wrangler types && vp lint --type-aware",
    "lint:fix": "wrangler types && vp lint --fix",
    "preview": "vp preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@cloudflare/vite-plugin": "1.46.0",
    "@radix-ui/react-dialog": "1.1.21",
    "@radix-ui/react-dropdown-menu": "2.1.22",
    "@radix-ui/react-slot": "1.3.1",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/query-async-storage-persister": "5.101.4",
    "@tanstack/react-hotkeys": "0.10.0",
    "@tanstack/react-query-persist-client": "5.101.4",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.32",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.26.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "shadcn": "4.14.0",
    "tailwind-merge": "3.6.0",
    "vaul-base": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
